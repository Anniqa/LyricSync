<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg_rounded"
    android:padding="14dp"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/overlay_cover"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/rounded_album_bg"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/overlay_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/overlay_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="1dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:id="@+id/overlay_toggle"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="Hide lyrics" />

        <ImageView
            android:id="@+id/overlay_settings"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />

        <ImageView
            android:id="@+id/overlay_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="5dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Close" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/overlay_settings_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lyrics Sync Offset"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_sync_offset_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ms (lyrics later)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <SeekBar
            android:id="@+id/overlay_sync_offset_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1500"
            android:min="-1500"
            android:progress="0"
            android:layout_marginTop="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lyrics ahead of singing? Increase. Lagging? Decrease."
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/overlay_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="36dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/overlay_lyrics_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </ScrollView>
</LinearLayout>
